# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from your secrets.
# Users configure this via the Secrets/Settings panel in the AI Studio UI.
GEMINI_API_KEY="your_gemini_api_key_here"

# JWT_SECRET: Secret key used to sign and verify JSON Web Tokens (JWT) for authentication.
# A default fallback is provided in the code, but you can override it here.
JWT_SECRET="lifesaver_os_ultra_secure_secret_token_1867145"

# MONGODB_URI: Optional MongoDB database connection string.
# If not provided, the applet automatically falls back to a highly resilient local JSON transactional file database.
MONGODB_URI="mongodb+srv://<username>:<password>@cluster.mongodb.net/lifesaver_os?retryWrites=true&w=majority"

# EMAIL_SERVICE: Optional preset service (e.g. gmail, mailgun)
EMAIL_SERVICE=

# EMAIL_HOST: SMTP host to connect to (e.g. smtp.mailtrap.io)
EMAIL_HOST=

# EMAIL_PORT: SMTP port (e.g. 2525, 587, 465)
EMAIL_PORT=

# EMAIL_USER: SMTP authentication username
EMAIL_USER=

# EMAIL_PASS: SMTP authentication password
EMAIL_PASS=

# FRONTEND_URL: The URL of the frontend dashboard (fallback to APP_URL if not specified)
FRONTEND_URL=
