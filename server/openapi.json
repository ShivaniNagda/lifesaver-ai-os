        }
      }
    },
    "/ai/agent-logs": {
      "get": {
        "summary": "Query multi-agent reasoning logs and system trace diagnostics",
        "tags": ["AI Core Operations"],
        "security": [{ "BearerAuth": [] }],
        "responses": {
          "200": { "description": "Active system traces" }
        }
      }
    },
    "/notifications": {
      "get": {
        "summary": "Retrieve warnings or custom system alert logs",
        "tags": ["Notifications Engine"],
        "security": [{ "BearerAuth": [] }],
        "responses": {
          "200": { "description": "Active alert list" }
        }
      },
      "post": {
        "summary": "Register a customized notification alert or diagnostics event",
        "tags": ["Notifications Engine"],
        "security": [{ "BearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": { "schema": { "$ref": "#/components/schemas/Notification" } }
          }
        },
        "responses": {
          "201": { "description": "Notification registered" }
        }
      }
    },
    "/notifications/history": {
      "get": {
        "summary": "Retrieve the history of dispatched smart email reminders",
        "tags": ["Notifications Engine"],
        "security": [{ "BearerAuth": [] }],
        "responses": {
          "200": { "description": "Array of sent email records and simulation logs" }
        }
      }
    },
    "/notifications/test-email": {
      "post": {
