        }
      },
      "delete": {
        "summary": "Remove a scheduled calendar event",
        "tags": ["Productivity Engine"],
        "security": [{ "BearerAuth": [] }],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string" }, "example": "event-999" }
        ],
        "responses": {
          "200": { "description": "Event deleted successfully" }
        }
      }
    },
    "/ai/process": {
      "post": {
        "summary": "Run active Gemini-driven planning simulation engine",
