        "summary": "Complete a habit for today and trigger streak counter",
        "tags": ["Productivity Engine"],
        "security": [{ "BearerAuth": [] }],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string" }, "example": "habit-123" }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": { "schema": { "$ref": "#/components/schemas/Habit" } }
          }
        },
        "responses": {
          "200": { "description": "Habit status updated successfully" }
        }
      },
      "delete": {
        "summary": "Permanently discard a habit tracking stream",
        "tags": ["Productivity Engine"],
        "security": [{ "BearerAuth": [] }],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string" }, "example": "habit-123" }
        ],
        "responses": {
          "200": { "description": "Habit deleted successfully" }
        }
      }
    },
    "/calendar": {
      "get": {
        "summary": "Retrieve planned schedule calendar events",
        "tags": ["Productivity Engine"],
        "security": [{ "BearerAuth": [] }],
        "responses": {
          "200": { "description": "List of active calendar schedules" }
        }
      },
      "post": {
        "summary": "Pin a block of time onto the interactive calendar",
        "tags": ["Productivity Engine"],
        "security": [{ "BearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": { "schema": { "$ref": "#/components/schemas/CalendarEvent" } }
